# Marketing version (e.g., "1.2.0"). Defaults to the value in ios/Info.plist.
# APP_VERSION=1.2.0

# Build number (integer). Defaults to auto-increment via git commit count.
# APP_BUILD_NUMBER=42

# Path to the release version of Xcode (beta Xcode builds are rejected by App Store Connect).
# The build system also respects the standard DEVELOPER_DIR env var.
# DEVELOPER_DIR=/Applications/Xcode.app/Contents/Developer

# GM toolchain builds the upload script pins against (defaults shown).
# Update after Apple ships a new GM — see https://xcodereleases.com
# EXPECTED_XCODE_BUILD=17F113
# EXPECTED_SDK_BUILD=23F81a

# App Store Connect API credentials (required for TestFlight upload)
APP_STORE_KEY_ID=XXXXXXXXXX
APP_STORE_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional: directory containing AuthKey_<KEY_ID>.p8 (defaults to ~/.private_keys)
# API_PRIVATE_KEYS_DIR=~/.private_keys

# Optional: codesign identity name (defaults to "Apple Distribution")
# SIGNING_IDENTITY=Apple Distribution

# Optional: path to .mobileprovision file
# PROVISIONING_PROFILE=~/Library/MobileDevice/Provisioning Profiles/yconnect.mobileprovision
